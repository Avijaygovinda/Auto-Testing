# Get free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Get free key from https://console.groq.com (used in Phase 2+)
GROQ_API_KEY=your_groq_key_here

# === Phase 4 v2 — real-device test credentials ===
# All FLUTTER_TEST_* values are made available to the AI navigator. It uses
# them when it sees forms asking for email, password, OTP, address, etc.
# Leave any unset → AI pauses via HITL and asks you for the value at runtime.
FLUTTER_TEST_EMAIL=test@example.com
FLUTTER_TEST_PASSWORD=Test1234!
FLUTTER_TEST_NEW_EMAIL_PREFIX=newuser
FLUTTER_TEST_NEW_PASSWORD=Test1234!
FLUTTER_TEST_OTP=1234
FLUTTER_TEST_PHONE=+15551234567
FLUTTER_TEST_NAME=QA Test
FLUTTER_TEST_ADDRESS=123 Main St
FLUTTER_TEST_PAYMENT_CARD=4242424242424242

# === HITL behavior overrides ===
# Set to 'yes' to skip the confirmation prompt for destructive actions.
FLOWTEST_AUTO_CONFIRM_DESTRUCTIVE=false
# Force-answer all HITL prompts to yes (unattended mode). Use carefully.
FLOWTEST_AUTO_CONFIRM=
